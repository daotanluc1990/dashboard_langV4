{
  "name": "comtam-dashboard-next",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm run local",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "local": "npm run clean && npm run build && set DASHBOARD_DEBUG=1&& next start --hostname 0.0.0.0 --port 3002",
    "dev:local": "npm run local",
    "dev:preview": "npm run local",
    "preview:local": "next start --hostname 0.0.0.0 --port 3000",
    "preview:clean": "next start --hostname 0.0.0.0 --port 3002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@googleapis/sheets": "^9.3.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^14.2.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "google-auth-library": "^9.15.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.16",
    "typescript": "^5.6.3"
  }
}
